#!/bin/bash
# Commit message hook for Syzygy

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Block attribution patterns
if echo "$COMMIT_MSG" | grep -iE "Co-Authored-By.*@|Generated with \[|noreply@" > /dev/null 2>&1; then
    echo "ERROR: Commit message contains attribution."
    exit 1
fi

# Check message length
FIRST_LINE=$(echo "$COMMIT_MSG" | head -1)
if [ ${#FIRST_LINE} -gt 72 ]; then
    echo "ERROR: Subject line exceeds 72 characters."
    exit 1
fi

exit 0
